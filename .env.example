# ============================================
# Tendance LK Marché — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# Anthropic Claude API
# Obtenir sur : https://console.anthropic.com
# Crédit de $5 offert à l'inscription
ANTHROPIC_API_KEY=

# Adzuna Jobs API (gratuit, 1000 calls/jour)
# Inscription sur : https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ============================================
# Sans ces clés, l'app fonctionne en mode démo
# avec des données simulées réalistes.
# ============================================
